{
  "name": "pollinate",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && pnpm run dev",
    "dev:client": "cd client && pnpm run dev",
    "build": "cd client && pnpm run build",
    "db:migrate": "cd server && pnpm run db:migrate",
    "typecheck": "cd server && pnpm run typecheck && cd ../client && pnpm run typecheck"
  }
}
